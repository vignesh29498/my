# ---------------------------------------------------------------------------
# Repository Connector
# ---------------------------------------------------------------------------
class RepoConnector:
    """Clone or fetch a GitHub repository, or use a local path."""

    def __init__(self, repo_identifier: str, token: Optional[str] = None):
        self.token = token or os.environ.get("GITHUB_TOKEN", "")
        self.is_local = os.path.isdir(repo_identifier)
        if self.is_local:
            self.owner = "local"
            self.name = Path(repo_identifier).name
            self.local_path: Optional[str] = os.path.abspath(repo_identifier)
        else:
            self.owner, self.name = self._parse_identifier(repo_identifier)
            self.local_path = None
        self.full_name = f"{self.owner}/{self.name}"
        self._gh = Github(self.token) if self.token else Github()
        self._repo = None

    @staticmethod
    def _parse_identifier(ident: str) -> tuple[str, str]:
        ident = ident.strip().rstrip("/")
        if "github.com" in ident:
            parts = ident.split("github.com/")[-1].split("/")
            if len(parts) >= 2:
                return parts[0], parts[1].replace(".git", "")
        if "/" in ident:
            parts = ident.split("/")
            return parts[0], parts[1]
        raise ValueError(f"Invalid repo identifier: {ident}. Use 'owner/repo', a GitHub URL, or a local path.")

    @property
    def repo(self):
        if self._repo is None:
            self._repo = self._gh.get_repo(self.full_name)
        return self._repo

    def clone(self, dest: Optional[str] = None) -> str:
        if self.is_local:
            print(f"[*] Using local repo: {self.local_path}")
            return self.local_path
        if dest is None:
            dest = tempfile.mkdtemp(prefix="gh_kg_")
        clone_url = self.repo.clone_url
        if self.token:
            clone_url = clone_url.replace("https://", f"https://x-access-token:{self.token}@")
        print(f"[*] Cloning {self.full_name} -> {dest} ...")
        subprocess.run(["git", "clone", "--depth=1", clone_url, dest],
                       capture_output=True, text=True, check=True)
        self.local_path = dest
        print(f"[+] Clone complete.")
        return dest

    def get_metadata(self) -> dict[str, Any]:
        if self.is_local:
            return {
                "name": self.full_name,
                "description": "(local repository)",
                "language": self._detect_language(),
                "stars": 0,
                "forks": 0,
                "open_issues": 0,
                "default_branch": "main",
                "topics": [],
                "url": f"file://{self.local_path}",
                "created_at": "",
                "updated_at": "",
                "license": "Unknown",
                "size_kb": 0,
            }
        r = self.repo
        return {
            "name": r.full_name,
            "description": r.description or "",
            "language": r.language or "Unknown",
            "stars": r.stargazers_count,
            "forks": r.forks_count,
            "open_issues": r.open_issues_count,
            "default_branch": r.default_branch,
            "topics": r.get_topics(),
            "url": r.html_url,
            "created_at": str(r.created_at),
            "updated_at": str(r.updated_at),
            "license": r.license.name if r.license else "None",
            "size_kb": r.size,
        }

    def _detect_language(self) -> str:
        if not self.local_path:
            return "Unknown"
        ext_counts: dict[str, int] = defaultdict(int)
        for fp in Path(self.local_path).rglob("*"):
            if fp.is_file() and fp.suffix in PARSEABLE_EXTENSIONS:
                ext_counts[fp.suffix] += 1
        ext_to_lang = {
            ".py": "Python", ".js": "JavaScript", ".ts": "TypeScript",
            ".java": "Java", ".go": "Go", ".rs": "Rust", ".rb": "Ruby",
            ".cpp": "C++", ".c": "C", ".cs": "C#", ".php": "PHP",
            ".swift": "Swift", ".kt": "Kotlin", ".scala": "Scala",
        }
        if ext_counts:
            top_ext = max(ext_counts, key=ext_counts.get)
            return ext_to_lang.get(top_ext, "Unknown")
        return "Unknown"


