# Data File Parser
# ---------------------------------------------------------------------------
class DataFileParser:
    """Parse CSV, Excel, Parquet, JSONL data files into summaries."""

    def parse(self, filepath: str, content_bytes: bytes, ext: str) -> dict[str, Any]:
        result: dict[str, Any] = {
            "path": filepath,
            "type": "data_file",
            "format": ext.lstrip("."),
            "columns": [],
            "row_count": 0,
            "dtypes": {},
            "sample_rows": [],
            "statistics": {},
            "null_counts": {},
        }
        if pd is None:
            result["error"] = "pandas not installed; skipped data parsing"
            return result

        try:
            df = self._read_dataframe(content_bytes, ext)
            if df is None or df.empty:
                result["error"] = "empty or unreadable"
                return result

            result["columns"] = list(df.columns)
            result["row_count"] = len(df)
            result["dtypes"] = {str(c): str(df[c].dtype) for c in df.columns}
            result["null_counts"] = {str(c): int(df[c].isna().sum()) for c in df.columns}

            sample = df.head(5)
            result["sample_rows"] = json.loads(sample.to_json(orient="records", default_handler=str))

            numeric_df = df.select_dtypes(include=["number"])
            if not numeric_df.empty:
                desc = numeric_df.describe()
                result["statistics"] = json.loads(desc.to_json(default_handler=str))

        except Exception as e:
            result["error"] = str(e)

        return result

    @staticmethod
    def _read_dataframe(content_bytes: bytes, ext: str):
        if pd is None:
            return None
        ext = ext.lower()
        try:
            if ext in (".csv", ".tsv"):
                sep = "\t" if ext == ".tsv" else ","
                return pd.read_csv(io.BytesIO(content_bytes), sep=sep, nrows=10000)
            elif ext in (".xlsx", ".xls"):
                return pd.read_excel(io.BytesIO(content_bytes), nrows=10000)
            elif ext in (".parquet", ".pq"):
                return pd.read_parquet(io.BytesIO(content_bytes))
            elif ext in (".jsonl", ".ndjson"):
                return pd.read_json(io.BytesIO(content_bytes), lines=True, nrows=10000)
        except Exception:
            return None
        return None


# ---------------------------------------------------------------------------
# Code Analyzer (enhanced with docstrings, complexity, TODOs)
# ---------------------------------------------------------------------------
class CodeAnalyzer:
    """Extract symbols, docstrings, complexity, and TODOs from source files."""

    def analyze_file(self, filepath: str, content: str) -> dict[str, Any]:
        ext = Path(filepath).suffix.lower()
        result: dict[str, Any] = {
            "path": filepath,
            "extension": ext,
            "classes": [],
            "functions": [],
            "imports": [],
            "exports": [],
            "global_variables": [],
            "decorators": [],
            "lines": content.count("\n") + 1,
            "docstrings": [],
            "todos": [],
            "complexity": {},
        }
        self._extract_todos(content, result)

        if ext == ".py":
            self._analyze_python(content, result)
        elif ext in (".js", ".jsx", ".ts", ".tsx"):
            self._analyze_js_ts(content, result)
        elif ext == ".java":
            self._analyze_java(content, result)
        elif ext == ".go":
            self._analyze_go(content, result)
        elif ext == ".rs":
            self._analyze_rust(content, result)
        elif ext == ".rb":
            self._analyze_ruby(content, result)
        elif ext in (".c", ".cpp", ".h", ".hpp"):
            self._analyze_c_cpp(content, result)
        elif ext == ".cs":
            self._analyze_csharp(content, result)
        elif ext == ".php":
            self._analyze_php(content, result)
        elif ext in (".kt", ".scala"):
            self._analyze_jvm(content, result)
        else:
            self._analyze_generic(content, result)
        return result

    def _extract_todos(self, content: str, result: dict) -> None:
        for i, line in enumerate(content.split("\n"), 1):
            m = re.search(r"#\s*(TODO|FIXME|HACK|XXX|BUG|NOTE)\b[:\s]*(.*)", line, re.IGNORECASE)
            if not m:
                m = re.search(r"//\s*(TODO|FIXME|HACK|XXX|BUG|NOTE)\b[:\s]*(.*)", line, re.IGNORECASE)
            if not m:
                m = re.search(r"\*\s*(TODO|FIXME|HACK|XXX|BUG|NOTE)\b[:\s]*(.*)", line, re.IGNORECASE)
            if m:
                result["todos"].append({
                    "type": m.group(1).upper(),
                    "text": m.group(2).strip(),
                    "line": i,
                })

    def _analyze_python(self, content: str, result: dict) -> None:
        try:
            tree = ast.parse(content)
        except SyntaxError:
            self._analyze_generic(content, result)
            return

        module_doc = ast.get_docstring(tree)
        if module_doc:
            result["docstrings"].append({"scope": "module", "text": module_doc.strip()})

        for node in ast.walk(tree):
            if isinstance(node, ast.ClassDef):
                bases = []
                for base in node.bases:
                    if isinstance(base, ast.Name):
                        bases.append(base.id)
                    elif isinstance(base, ast.Attribute):
                        parts = []
                        cur = base
                        while isinstance(cur, ast.Attribute):
                            parts.append(cur.attr)
                            cur = cur.value
                        if isinstance(cur, ast.Name):
                            parts.append(cur.id)
                        bases.append(".".join(reversed(parts)))
                methods = []
                for n in node.body:
                    if isinstance(n, (ast.FunctionDef, ast.AsyncFunctionDef)):
                        methods.append(n.name)
                decorators = []
                for dec in node.decorator_list:
                    if isinstance(dec, ast.Name):
                        decorators.append(dec.id)
                    elif isinstance(dec, ast.Attribute):
                        decorators.append(self._attr_to_str(dec))

                cls_doc = ast.get_docstring(node)
                if cls_doc:
                    result["docstrings"].append({
                        "scope": f"class:{node.name}",
                        "text": cls_doc.strip()[:500],
                    })

                result["classes"].append({
                    "name": node.name,
                    "bases": bases,
                    "methods": methods,
                    "decorators": decorators,
                    "line": node.lineno,
                    "docstring": (cls_doc or "")[:200],
                })

            elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
                is_method = False
                for parent in ast.walk(tree):
                    if isinstance(parent, ast.ClassDef) and node in parent.body:
                        is_method = True
                        break

                args = [a.arg for a in node.args.args]
                decorators = []
                for dec in node.decorator_list:
                    if isinstance(dec, ast.Name):
                        decorators.append(dec.id)

                fn_doc = ast.get_docstring(node)
                if fn_doc:
                    result["docstrings"].append({
                        "scope": f"{'method' if is_method else 'function'}:{node.name}",
                        "text": fn_doc.strip()[:500],
                    })

                complexity = self._cyclomatic_complexity(node)

                if not is_method:
                    result["functions"].append({
                        "name": node.name,
                        "args": args,
                        "decorators": decorators,
                        "is_async": isinstance(node, ast.AsyncFunctionDef),
                        "line": node.lineno,
                        "docstring": (fn_doc or "")[:200],
                        "complexity": complexity,
                    })

            elif isinstance(node, ast.Import):
                for alias in node.names:
                    result["imports"].append({
                        "module": alias.name,
                        "alias": alias.asname,
                        "type": "import",
                    })
            elif isinstance(node, ast.ImportFrom):
                module = node.module or ""
                for alias in node.names:
                    result["imports"].append({
                        "module": module,
                        "name": alias.name,
                        "alias": alias.asname,
                        "type": "from_import",
                    })
            elif isinstance(node, ast.Assign):
                for target in node.targets:
                    if isinstance(target, ast.Name) and target.id.isupper():
                        result["global_variables"].append({
                            "name": target.id, "line": node.lineno,
                        })

        result["complexity"] = {
            "total_branches": self._count_branches(tree),
            "max_depth": self._max_nesting_depth(tree),
        }

    @staticmethod
    def _attr_to_str(node) -> str:
        parts = []
        cur = node
        while isinstance(cur, ast.Attribute):
            parts.append(cur.attr)
            cur = cur.value
        if isinstance(cur, ast.Name):
            parts.append(cur.id)
        return ".".join(reversed(parts))

    @staticmethod
    def _cyclomatic_complexity(node) -> int:
        complexity = 1
        for child in ast.walk(node):
            if isinstance(child, (ast.If, ast.While, ast.For, ast.ExceptHandler)):
                complexity += 1
            elif isinstance(child, ast.BoolOp):
                complexity += len(child.values) - 1
            elif isinstance(child, ast.Assert):
                complexity += 1
            elif isinstance(child, (ast.ListComp, ast.SetComp, ast.DictComp, ast.GeneratorExp)):
                complexity += 1
        return complexity

    @staticmethod
    def _count_branches(tree) -> int:
        count = 0
        for node in ast.walk(tree):
            if isinstance(node, (ast.If, ast.While, ast.For, ast.ExceptHandler,
                                 ast.With, ast.Try)):
                count += 1
        return count

    @staticmethod
    def _max_nesting_depth(tree, depth=0) -> int:
        max_d = depth
        for node in ast.iter_child_nodes(tree):
            if isinstance(node, (ast.If, ast.While, ast.For, ast.With,
                                 ast.Try, ast.FunctionDef, ast.AsyncFunctionDef)):
                child_d = CodeAnalyzer._max_nesting_depth(node, depth + 1)
                max_d = max(max_d, child_d)
            else:
                child_d = CodeAnalyzer._max_nesting_depth(node, depth)
                max_d = max(max_d, child_d)
        return max_d

    def _analyze_js_ts(self, content: str, result: dict) -> None:
        for m in re.finditer(r'/\*\*\s*([\s\S]*?)\*/', content):
            doc = re.sub(r'^\s*\*\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "jsdoc", "text": doc[:500]})
        for m in re.finditer(
            r'''import\s+(?:(\{[^}]+\})|(\w+))?\s*(?:,\s*(?:(\{[^}]+\})|(\w+)))?\s*from\s*['"]([\w@/.~-]+)['"]''',
            content,
        ):
            module = m.group(5)
            names = []
            for g in [m.group(1), m.group(3)]:
                if g:
                    names.extend(n.strip().split(" as ")[0].strip() for n in g.strip("{}").split(","))
            for g in [m.group(2), m.group(4)]:
                if g:
                    names.append(g)
            result["imports"].append({"module": module, "names": names})
        for m in re.finditer(r'''require\(\s*['"]([\w@/.~-]+)['"]\s*\)''', content):
            result["imports"].append({"module": m.group(1), "type": "require"})
        for m in re.finditer(r"class\s+(\w+)(?:\s+extends\s+(\w+))?", content):
            result["classes"].append({
                "name": m.group(1),
                "bases": [m.group(2)] if m.group(2) else [],
            })
        for m in re.finditer(r"(?:export\s+)?(?:async\s+)?function\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})
        for m in re.finditer(r"(?:export\s+)?const\s+(\w+)\s*=\s*(?:async\s+)?\(", content):
            result["functions"].append({"name": m.group(1)})
        for m in re.finditer(r"export\s+(?:default\s+)?(?:class|function|const|let|var)\s+(\w+)", content):
            result["exports"].append(m.group(1))
        for m in re.finditer(r"module\.exports\s*=\s*(\w+)", content):
            result["exports"].append(m.group(1))

    def _analyze_java(self, content: str, result: dict) -> None:
        for m in re.finditer(r'/\*\*\s*([\s\S]*?)\*/', content):
            doc = re.sub(r'^\s*\*\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "javadoc", "text": doc[:500]})
        for m in re.finditer(r"import\s+([\w.]+);", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(
            r"(?:public|private|protected)?\s*(?:abstract\s+)?class\s+(\w+)"
            r"(?:\s+extends\s+(\w+))?(?:\s+implements\s+([\w,\s]+))?",
            content,
        ):
            bases = [m.group(2)] if m.group(2) else []
            if m.group(3):
                bases.extend(i.strip() for i in m.group(3).split(","))
            result["classes"].append({"name": m.group(1), "bases": bases})
        for m in re.finditer(
            r"(?:public|private|protected)?\s*(?:static\s+)?(?:[\w<>\[\]]+)\s+(\w+)\s*\(",
            content,
        ):
            if m.group(1) not in ("if", "for", "while", "switch", "catch"):
                result["functions"].append({"name": m.group(1)})

    def _analyze_go(self, content: str, result: dict) -> None:
        for m in re.finditer(r'((?://[^\n]*\n)+)\s*(?:func|type|var|const)', content):
            doc = re.sub(r'^//\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "godoc", "text": doc[:500]})
        for m in re.finditer(r'"([\w/.]+)"', content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"type\s+(\w+)\s+struct", content):
            result["classes"].append({"name": m.group(1), "type": "struct"})
        for m in re.finditer(r"type\s+(\w+)\s+interface", content):
            result["classes"].append({"name": m.group(1), "type": "interface"})
        for m in re.finditer(r"func\s+(?:\(\w+\s+\*?(\w+)\)\s+)?(\w+)\s*\(", content):
            fn = {"name": m.group(2)}
            if m.group(1):
                fn["receiver"] = m.group(1)
            result["functions"].append(fn)

    def _analyze_rust(self, content: str, result: dict) -> None:
        for m in re.finditer(r'((?:///[^\n]*\n)+)', content):
            doc = re.sub(r'^///\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "rustdoc", "text": doc[:500]})
        for m in re.finditer(r"use\s+([\w:]+)", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"struct\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "struct"})
        for m in re.finditer(r"enum\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "enum"})
        for m in re.finditer(r"trait\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "trait"})
        for m in re.finditer(r"(?:pub\s+)?(?:async\s+)?fn\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})
        for m in re.finditer(r"impl\s+(?:(\w+)\s+for\s+)?(\w+)", content):
            entry = {"name": m.group(2), "type": "impl"}
            if m.group(1):
                entry["trait"] = m.group(1)
            result["classes"].append(entry)

    def _analyze_ruby(self, content: str, result: dict) -> None:
        for m in re.finditer(r"require\s+['\"](.+?)['\"]", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"class\s+(\w+)(?:\s*<\s*(\w+))?", content):
            result["classes"].append({
                "name": m.group(1),
                "bases": [m.group(2)] if m.group(2) else [],
            })
        for m in re.finditer(r"module\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "module"})
        for m in re.finditer(r"def\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})

    def _analyze_c_cpp(self, content: str, result: dict) -> None:
        for m in re.finditer(r'/\*[*!]\s*([\s\S]*?)\*/', content):
            doc = re.sub(r'^\s*\*\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "doxygen", "text": doc[:500]})
        for m in re.finditer(r'#include\s*[<"]([\w/.\-]+)[>"]', content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"class\s+(\w+)(?:\s*:\s*(?:public|private|protected)\s+(\w+))?", content):
            result["classes"].append({
                "name": m.group(1),
                "bases": [m.group(2)] if m.group(2) else [],
            })
        for m in re.finditer(r"(?:struct|union)\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "struct"})
        for m in re.finditer(r"(?:[\w*&:<>]+\s+)+(\w+)\s*\([^)]*\)\s*(?:const\s*)?(?:\{|;)", content):
            if m.group(1) not in ("if", "for", "while", "switch", "return", "catch"):
                result["functions"].append({"name": m.group(1)})

    def _analyze_csharp(self, content: str, result: dict) -> None:
        for m in re.finditer(r'((?:///[^\n]*\n)+)', content):
            doc = re.sub(r'^///\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "xmldoc", "text": doc[:500]})
        for m in re.finditer(r"using\s+([\w.]+);", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(
            r"(?:public|private|internal|protected)?\s*(?:abstract|static|sealed)?\s*class\s+(\w+)"
            r"(?:\s*:\s*([\w,\s<>]+))?",
            content,
        ):
            bases = [b.strip() for b in m.group(2).split(",")] if m.group(2) else []
            result["classes"].append({"name": m.group(1), "bases": bases})
        for m in re.finditer(r"interface\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "interface"})

    def _analyze_php(self, content: str, result: dict) -> None:
        for m in re.finditer(r'/\*\*\s*([\s\S]*?)\*/', content):
            doc = re.sub(r'^\s*\*\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "phpdoc", "text": doc[:500]})
        for m in re.finditer(r"use\s+([\w\\]+)", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"require(?:_once)?\s*\(?\s*['\"](.+?)['\"]\s*\)?", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"class\s+(\w+)(?:\s+extends\s+(\w+))?", content):
            result["classes"].append({
                "name": m.group(1),
                "bases": [m.group(2)] if m.group(2) else [],
            })
        for m in re.finditer(r"function\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})

    def _analyze_jvm(self, content: str, result: dict) -> None:
        for m in re.finditer(r'/\*\*\s*([\s\S]*?)\*/', content):
            doc = re.sub(r'^\s*\*\s?', '', m.group(1), flags=re.MULTILINE).strip()
            if doc and len(doc) > 10:
                result["docstrings"].append({"scope": "kdoc", "text": doc[:500]})
        for m in re.finditer(r"import\s+([\w.]+)", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"(?:data\s+)?class\s+(\w+)(?:\s*[:(<]\s*(\w+))?", content):
            result["classes"].append({
                "name": m.group(1),
                "bases": [m.group(2)] if m.group(2) else [],
            })
        for m in re.finditer(r"object\s+(\w+)", content):
            result["classes"].append({"name": m.group(1), "type": "object"})
        for m in re.finditer(r"(?:fun|def)\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})

    def _analyze_generic(self, content: str, result: dict) -> None:
        for m in re.finditer(r"(?:import|require|include|use)\s+['\"]?([\w./\\@-]+)", content):
            result["imports"].append({"module": m.group(1)})
        for m in re.finditer(r"(?:class|struct|interface|type)\s+(\w+)", content):
            result["classes"].append({"name": m.group(1)})
        for m in re.finditer(r"(?:function|func|def|fn)\s+(\w+)", content):
            result["functions"].append({"name": m.group(1)})


# ---------------------------------------------------------------------------
# Knowledge Graph Builder  (igraph version)
# ---------------------------------------------------------------------------
class KnowledgeGraphBuilder:
    """Build an igraph knowledge graph from analyzed files."""

    def __init__(self):
        self.graph = ig.Graph(directed=True)
        self._vertex_index: dict[str, int] = {}  # name -> vertex index
        self.file_analyses: list[dict] = []
        self.data_summaries: list[dict] = []
        self.doc_contents: dict[str, str] = {}

    # -- helpers for igraph vertex management --
    def _ensure_vertex(self, name: str, **attrs) -> int:
        """Add a vertex if it doesn't exist yet; return its index."""
        if name in self._vertex_index:
            idx = self._vertex_index[name]
            # Update attributes on existing vertex
            for k, v in attrs.items():
                self.graph.vs[idx][k] = v
            return idx
        idx = self.graph.vcount()
        self.graph.add_vertex(name=name, **attrs)
        self._vertex_index[name] = idx
        return idx

    def _has_vertex(self, name: str) -> bool:
        return name in self._vertex_index

    def _add_edge(self, source_name: str, target_name: str, **attrs) -> None:
        """Add an edge between two vertices (by name). Creates target if needed."""
        src = self._ensure_vertex(source_name)
        tgt = self._ensure_vertex(target_name)
        self.graph.add_edge(src, tgt, **attrs)

    # -- public API (same interface as networkx version) --
    def add_repo_metadata(self, metadata: dict) -> None:
        extra = {k: str(v) for k, v in metadata.items() if k != "name"}
        self._ensure_vertex(
            metadata["name"], type="repository", **extra,
        )

    def add_doc_content(self, rel_path: str, content: str) -> None:
        self.doc_contents[rel_path] = content

    def add_data_summary(self, summary: dict) -> None:
        self.data_summaries.append(summary)
        fpath = summary["path"]
        self._ensure_vertex(fpath, type="data_file",
                            format=summary.get("format", ""),
                            row_count=summary.get("row_count", 0),
                            columns=str(summary.get("columns", [])))

    def add_file_analysis(self, analysis: dict) -> None:
        self.file_analyses.append(analysis)
        fpath = analysis["path"]
        self._ensure_vertex(fpath, type="file",
                            extension=analysis["extension"],
                            lines=analysis["lines"])

        parts = Path(fpath).parts
        for i in range(len(parts) - 1):
            parent = str(Path(*parts[: i + 1]))
            child = str(Path(*parts[: i + 2]))
            if not self._has_vertex(parent):
                self._ensure_vertex(parent, type="directory")
            self._add_edge(parent, child, relation="contains")

        for cls in analysis["classes"]:
            cls_id = f"{fpath}::{cls['name']}"
            attrs: dict[str, Any] = {"type": "class", "node_name": cls["name"]}
            if "type" in cls:
                attrs["subtype"] = cls["type"]
            if cls.get("docstring"):
                attrs["docstring"] = cls["docstring"][:200]
            self._ensure_vertex(cls_id, **attrs)
            self._add_edge(fpath, cls_id, relation="defines")
            for base in cls.get("bases", []):
                self._add_edge(cls_id, base, relation="inherits")
            for method in cls.get("methods", []):
                m_id = f"{cls_id}.{method}"
                self._ensure_vertex(m_id, type="method", node_name=method)
                self._add_edge(cls_id, m_id, relation="has_method")

        for fn in analysis["functions"]:
            fn_id = f"{fpath}::{fn['name']}"
            attrs = {"type": "function", "node_name": fn["name"]}
            if fn.get("is_async"):
                attrs["is_async"] = True
            if fn.get("receiver"):
                attrs["receiver"] = fn["receiver"]
            if fn.get("docstring"):
                attrs["docstring"] = fn["docstring"][:200]
            if fn.get("complexity"):
                attrs["complexity"] = fn["complexity"]
            self._ensure_vertex(fn_id, **attrs)
            self._add_edge(fpath, fn_id, relation="defines")

        for imp in analysis["imports"]:
            module = imp.get("module", "")
            if module:
                self._add_edge(fpath, module, relation="imports")

    def build_dependency_map(self) -> dict[str, list[str]]:
        internal_files = {a["path"] for a in self.file_analyses}
        deps: dict[str, list[str]] = defaultdict(list)
        for analysis in self.file_analyses:
            fpath = analysis["path"]
            for imp in analysis["imports"]:
                module = imp.get("module", "")
                candidates = self._resolve_import(module, internal_files)
                for c in candidates:
                    deps[fpath].append(c)
        return dict(deps)

    @staticmethod
    def _resolve_import(module: str, internal_files: set[str]) -> list[str]:
        if not module:
            return []
        candidates = []
        path_forms = [
            module.replace(".", "/"), module.replace(".", "/") + ".py",
            module.replace(".", "/") + "/index.ts", module.replace(".", "/") + "/index.js",
            module.replace(".", "/") + ".ts", module.replace(".", "/") + ".js",
            module.replace(".", "/") + ".java", module.replace(".", "/") + ".go",
            module,
        ]
        for pf in path_forms:
            for f in internal_files:
                if f.endswith(pf) or f == pf:
                    candidates.append(f)
        return candidates

    def compute_centrality(self) -> dict[str, dict[str, float]]:
        metrics: dict[str, dict[str, float]] = {}

        # Collect file-type vertices
        file_names = []
        for idx in range(self.graph.vcount()):
            if self.graph.vs[idx].attributes().get("type") == "file":
                file_names.append(self.graph.vs[idx]["name"])

        if len(file_names) < 2:
            return metrics

        # Build a file-only subgraph
        file_graph = ig.Graph(directed=True)
        file_graph.add_vertices(len(file_names))
        for i, fn in enumerate(file_names):
            file_graph.vs[i]["name"] = fn
        file_name_set = set(file_names)
        file_idx_map = {fn: i for i, fn in enumerate(file_names)}

        for eid in range(self.graph.ecount()):
            edge = self.graph.es[eid]
            src_name = self.graph.vs[edge.source]["name"]
            rel = edge.attributes().get("relation", "")
            if rel == "imports" and src_name in file_name_set:
                tgt_name = self.graph.vs[edge.target]["name"]
                for fn in file_names:
                    if fn.endswith(tgt_name) or fn.endswith(tgt_name.replace(".", "/")) or tgt_name in fn:
                        file_graph.add_edge(file_idx_map[src_name], file_idx_map[fn])

        if file_graph.ecount() == 0:
            return metrics

        try:
            # igraph centrality functions
            n = file_graph.vcount()
            in_deg = file_graph.degree(mode="in")
            # Normalize in-degree centrality like networkx does: / (n-1)
            norm = max(n - 1, 1)
            in_deg_centrality = [d / norm for d in in_deg]

            pr = file_graph.pagerank(damping=0.85)
            betw = file_graph.betweenness(directed=True)
            # Normalize betweenness like networkx: / ((n-1)*(n-2))
            betw_norm = max((n - 1) * (n - 2), 1)
            betw_normalized = [b / betw_norm for b in betw]

            for i, fn in enumerate(file_names):
                metrics[fn] = {
                    "in_degree_centrality": round(in_deg_centrality[i], 4),
                    "pagerank": round(pr[i], 6),
                    "betweenness": round(betw_normalized[i], 4),
                }
        except Exception:
            pass

        return metrics

    def get_statistics(self) -> dict[str, Any]:
        type_counts: dict[str, int] = defaultdict(int)
        for idx in range(self.graph.vcount()):
            type_counts[self.graph.vs[idx].attributes().get("type", "unknown")] += 1

        relation_counts: dict[str, int] = defaultdict(int)
        for eid in range(self.graph.ecount()):
            relation_counts[self.graph.es[eid].attributes().get("relation", "unknown")] += 1

        total_complexity = 0
        fn_count = 0
        for a in self.file_analyses:
            for fn in a["functions"]:
                if fn.get("complexity"):
                    total_complexity += fn["complexity"]
                    fn_count += 1

        return {
            "total_nodes": self.graph.vcount(),
            "total_edges": self.graph.ecount(),
            "node_types": dict(type_counts),
            "edge_types": dict(relation_counts),
            "total_files_analyzed": len(self.file_analyses),
            "total_data_files": len(self.data_summaries),
            "total_classes": sum(len(a["classes"]) for a in self.file_analyses),
            "total_functions": sum(len(a["functions"]) for a in self.file_analyses),
            "total_imports": sum(len(a["imports"]) for a in self.file_analyses),
            "total_docstrings": sum(len(a.get("docstrings", [])) for a in self.file_analyses),
            "total_todos": sum(len(a.get("todos", [])) for a in self.file_analyses),
            "avg_complexity": round(total_complexity / fn_count, 2) if fn_count else 0,
        }

    # -- helpers for LLMFormatter to iterate the graph --
    def iter_nodes(self):
        """Yield (name, attrs_dict) for every vertex."""
        for idx in range(self.graph.vcount()):
            v = self.graph.vs[idx]
            attrs = {k: v[k] for k in v.attributes() if v[k] is not None}
            name = attrs.pop("name", str(idx))
            yield name, attrs

    def iter_edges(self):
        """Yield (source_name, target_name, attrs_dict) for every edge."""
        for eid in range(self.graph.ecount()):
            e = self.graph.es[eid]
            src_name = self.graph.vs[e.source]["name"]
            tgt_name = self.graph.vs[e.target]["name"]
            attrs = {k: e[k] for k in e.attributes() if e[k] is not None}
            yield src_name, tgt_name, attrs

    def iter_edges_with_relation(self, relation: str):
        """Yield (source_name, target_name) for edges matching a relation."""
        for eid in range(self.graph.ecount()):
            e = self.graph.es[eid]
            if e.attributes().get("relation") == relation:
                yield self.graph.vs[e.source]["name"], self.graph.vs[e.target]["name"]


# ---------------------------------------------------------------------------
# Directory Tree Builder
# ---------------------------------------------------------------------------
class TreeBuilder:
    def __init__(self, root: str, skip_dirs: set[str] = None, skip_files: set[str] = None):
        self.root = Path(root)
        self.skip_dirs = skip_dirs or SKIP_DIRS
        self.skip_files = skip_files or SKIP_FILES

    def build(self) -> str:
        lines = [f"{self.root.name}/"]
        self._walk(self.root, "", lines)
        return "\n".join(lines)

    def _walk(self, directory: Path, prefix: str, lines: list[str]) -> None:
        entries = sorted(directory.iterdir(), key=lambda e: (not e.is_dir(), e.name.lower()))
        entries = [
            e for e in entries
            if not (e.is_dir() and e.name in self.skip_dirs)
            and not (e.is_file() and e.name in self.skip_files)
            and e.name != ".git"
        ]
        for i, entry in enumerate(entries):
            is_last = i == len(entries) - 1
            connector = "\\-- " if is_last else "|-- "
            if entry.is_dir():
                lines.append(f"{prefix}{connector}{entry.name}/")
                extension = "    " if is_last else "|   "
                self._walk(entry, prefix + extension, lines)
            else:
                lines.append(f"{prefix}{connector}{entry.name}")


# ---------------------------------------------------------------------------
# LLM Output Formatter
# ---------------------------------------------------------------------------
class LLMFormatter:

    @staticmethod
    def format_txt(
        metadata: dict,
        tree_str: str,
        graph_builder: KnowledgeGraphBuilder,
        dep_map: dict[str, list[str]],
        centrality: dict[str, dict[str, float]],
    ) -> str:
        sections = []

        sections.append("=" * 80)
        sections.append("REPOSITORY KNOWLEDGE GRAPH -- LLM CONTEXT DOCUMENT")
        sections.append("=" * 80)
        sections.append("")

        sections.append("## 1. Repository Overview")
        for k, v in metadata.items():
            label = k.replace("_", " ").title().ljust(14)
            val = ", ".join(v) if isinstance(v, list) else str(v)
            sections.append(f"  {label}: {val}")
        sections.append("")

        stats = graph_builder.get_statistics()
        sections.append("## 2. Knowledge Graph Statistics")
        for k, v in stats.items():
            label = k.replace("_", " ").title().ljust(22)
            if isinstance(v, dict):
                sections.append(f"  {label}:")
                for sk, sv in v.items():
                    sections.append(f"    {sk}: {sv}")
            else:
                sections.append(f"  {label}: {v}")
        sections.append("")

        sections.append("## 3. Directory Tree")
        sections.append("```")
        sections.append(tree_str)
        sections.append("```")
        sections.append("")

        if graph_builder.doc_contents:
            sections.append("## 4. Documentation Summaries")
            for doc_path, content in sorted(graph_builder.doc_contents.items()):
                sections.append(f"\n### {doc_path}")
                summary = content[:2000]
                if len(content) > 2000:
                    summary += "\n... [truncated]"
                sections.append(summary)
            sections.append("")

        sections.append("## 5. File -> Symbol Map (Classes, Functions, Docstrings)")
        sections.append("")
        for analysis in sorted(graph_builder.file_analyses, key=lambda a: a["path"]):
            if not analysis["classes"] and not analysis["functions"]:
                continue
            complexity_info = ""
            if analysis.get("complexity", {}).get("total_branches"):
                complexity_info = f"  | branches={analysis['complexity']['total_branches']}, max_depth={analysis['complexity']['max_depth']}"
            sections.append(f"### {analysis['path']}  ({analysis['lines']} lines){complexity_info}")
            for cls in analysis["classes"]:
                bases_str = f"  <- {', '.join(cls['bases'])}" if cls.get("bases") else ""
                type_label = cls.get("type", "class").capitalize()
                sections.append(f"  [{type_label}] {cls['name']}{bases_str}")
                if cls.get("docstring"):
                    sections.append(f"    \"\"\"{cls['docstring'][:150]}\"\"\"")
                for method in cls.get("methods", []):
                    sections.append(f"    . {method}()")
            for fn in analysis["functions"]:
                async_tag = " (async)" if fn.get("is_async") else ""
                receiver_tag = f" [{fn['receiver']}]" if fn.get("receiver") else ""
                cx_tag = f" [complexity={fn['complexity']}]" if fn.get("complexity") else ""
                sections.append(f"  [Function] {fn['name']}(){async_tag}{receiver_tag}{cx_tag}")
                if fn.get("docstring"):
                    sections.append(f"    \"\"\"{fn['docstring'][:150]}\"\"\"")
            sections.append("")

        sections.append("## 6. Import / Dependency Graph")
        imports_by_file: dict[str, list[str]] = defaultdict(list)
        for analysis in graph_builder.file_analyses:
            for imp in analysis["imports"]:
                module = imp.get("module", "")
                if module:
                    imports_by_file[analysis["path"]].append(module)
        for fpath in sorted(imports_by_file.keys()):
            sections.append(f"  {fpath}")
            for mod in sorted(set(imports_by_file[fpath])):
                sections.append(f"    -> {mod}")
            sections.append("")

        if dep_map:
            sections.append("## 7. Internal File Dependencies")
            for src in sorted(dep_map.keys()):
                for dst in sorted(set(dep_map[src])):
                    sections.append(f"  {src}  ->  {dst}")
            sections.append("")

        inheritance_edges = list(graph_builder.iter_edges_with_relation("inherits"))
        if inheritance_edges:
            sections.append("## 8. Inheritance / Type Hierarchy")
            for child, parent in sorted(inheritance_edges):
                sections.append(f"  {child}  extends  {parent}")
            sections.append("")

        if centrality:
            sections.append("## 9. Key Files by Importance (PageRank + Centrality)")
            ranked = sorted(centrality.items(), key=lambda x: x[1].get("pagerank", 0), reverse=True)
            for fpath, metrics in ranked[:30]:
                sections.append(
                    f"  {fpath}  "
                    f"[pagerank={metrics.get('pagerank',0):.4f}, "
                    f"in_degree={metrics.get('in_degree_centrality',0):.4f}, "
                    f"betweenness={metrics.get('betweenness',0):.4f}]"
                )
            sections.append("")

        if graph_builder.data_summaries:
            sections.append("## 10. Data File Summaries")
            for ds in graph_builder.data_summaries:
                sections.append(f"\n### {ds['path']}  (format: {ds.get('format', '?')}, rows: {ds.get('row_count', '?')})")
                if ds.get("columns"):
                    sections.append(f"  Columns: {', '.join(ds['columns'][:30])}")
                if ds.get("dtypes"):
                    sections.append(f"  Types: {json.dumps(ds['dtypes'])}")
                if ds.get("statistics"):
                    sections.append(f"  Statistics:")
                    for col, stat_vals in ds["statistics"].items():
                        sections.append(f"    {col}: {json.dumps(stat_vals, default=str)}")
                if ds.get("sample_rows"):
                    sections.append(f"  Sample rows:")
                    for row in ds["sample_rows"][:3]:
                        sections.append(f"    {json.dumps(row, default=str)}")
            sections.append("")

        all_todos = []
        for analysis in graph_builder.file_analyses:
            for todo in analysis.get("todos", []):
                all_todos.append({"file": analysis["path"], **todo})
        if all_todos:
            sections.append("## 11. TODOs / FIXMEs / Notes")
            for t in sorted(all_todos, key=lambda x: x["type"]):
                sections.append(f"  [{t['type']}] {t['file']}:{t['line']} - {t['text']}")
            sections.append("")

        sections.append("## 12. Knowledge Graph (JSON -- Nodes & Edges)")
        kg_json = {"nodes": [], "edges": []}
        for node_name, data in graph_builder.iter_nodes():
            entry = {"id": str(node_name), **{k: str(v) for k, v in data.items()}}
            kg_json["nodes"].append(entry)
        for u, v, data in graph_builder.iter_edges():
            kg_json["edges"].append({
                "source": str(u), "target": str(v),
                "relation": data.get("relation", ""),
            })
        sections.append("```json")
        sections.append(json.dumps(kg_json, indent=2))
        sections.append("```")
        sections.append("")

        sections.append("=" * 80)
        sections.append("END OF KNOWLEDGE GRAPH DOCUMENT")
        sections.append("=" * 80)
        return "\n".join(sections)

    @staticmethod
    def format_jsonl(
        graph_builder: KnowledgeGraphBuilder,
        metadata: dict,
        dep_map: dict[str, list[str]],
        centrality: dict[str, dict[str, float]],
    ) -> str:
        lines = []
        lines.append(json.dumps({"type": "repository", **metadata}, default=str))
        for analysis in graph_builder.file_analyses:
            entry = {
                "type": "file_analysis",
                "path": analysis["path"],
                "extension": analysis["extension"],
                "lines": analysis["lines"],
                "classes": [{"name": c["name"], "bases": c.get("bases", []),
                             "methods": c.get("methods", []),
                             "docstring": c.get("docstring", "")} for c in analysis["classes"]],
                "functions": [{"name": f["name"],
                               "is_async": f.get("is_async", False),
                               "complexity": f.get("complexity", 0),
                               "docstring": f.get("docstring", "")} for f in analysis["functions"]],
                "imports": analysis["imports"],
                "todos": analysis.get("todos", []),
                "complexity": analysis.get("complexity", {}),
            }
            if analysis["path"] in centrality:
                entry["centrality"] = centrality[analysis["path"]]
            lines.append(json.dumps(entry, default=str))
        for ds in graph_builder.data_summaries:
            lines.append(json.dumps({"type": "data_file", **ds}, default=str))
        for src, targets in dep_map.items():
            lines.append(json.dumps({
                "type": "dependency",
                "source": src,
                "targets": list(set(targets)),
            }))
        for u, v, d in graph_builder.iter_edges():
            lines.append(json.dumps({
                "type": "edge",
                "source": str(u),
                "target": str(v),
                "relation": d.get("relation", ""),
            }))
        return "\n".join(lines)

    @staticmethod
    def format_markdown(
        metadata: dict,
        tree_str: str,
        graph_builder: KnowledgeGraphBuilder,
        dep_map: dict[str, list[str]],
        centrality: dict[str, dict[str, float]],
    ) -> str:
        md = []
        md.append(f"# Knowledge Graph: {metadata['name']}")
        md.append(f"\n> {metadata['description']}\n")
        md.append(f"**Language:** {metadata['language']} | "
                   f"**Stars:** {metadata['stars']} | "
                   f"**License:** {metadata.get('license', 'N/A')}\n")

        stats = graph_builder.get_statistics()
        md.append("## Statistics\n")
        md.append("| Metric | Value |")
        md.append("|--------|-------|")
        for k, v in stats.items():
            if not isinstance(v, dict):
                md.append(f"| {k.replace('_', ' ').title()} | {v} |")
        md.append("")

        md.append("## Directory Tree\n")
        md.append("```")
        md.append(tree_str)
        md.append("```\n")

        if centrality:
            md.append("## Key Files (by PageRank)\n")
            md.append("| File | PageRank | In-Degree | Betweenness |")
            md.append("|------|----------|-----------|-------------|")
            ranked = sorted(centrality.items(), key=lambda x: x[1].get("pagerank", 0), reverse=True)
            for fpath, m in ranked[:20]:
                md.append(f"| `{fpath}` | {m.get('pagerank',0):.4f} | "
                          f"{m.get('in_degree_centrality',0):.4f} | {m.get('betweenness',0):.4f} |")
            md.append("")

        all_classes = []
        for a in graph_builder.file_analyses:
            for cls in a["classes"]:
                all_classes.append({"file": a["path"], **cls})
        if all_classes:
            md.append("## Classes\n")
            md.append("| File | Class | Inherits | Methods |")
            md.append("|------|-------|----------|---------|")
            for cls in all_classes:
                bases = ", ".join(cls.get("bases", [])) or "-"
                methods = ", ".join(cls.get("methods", [])[:5]) or "-"
                if len(cls.get("methods", [])) > 5:
                    methods += f" (+{len(cls['methods'])-5} more)"
                md.append(f"| `{cls['file']}` | **{cls['name']}** | {bases} | {methods} |")
            md.append("")

        if graph_builder.data_summaries:
            md.append("## Data Files\n")
            for ds in graph_builder.data_summaries:
                md.append(f"### `{ds['path']}`\n")
                md.append(f"- **Format:** {ds.get('format', '?')}")
                md.append(f"- **Rows:** {ds.get('row_count', '?')}")
                if ds.get("columns"):
                    md.append(f"- **Columns:** {', '.join(ds['columns'][:15])}")
                md.append("")

        return "\n".join(md)


# ---------------------------------------------------------------------------
# Main Pipeline
# ---------------------------------------------------------------------------
def run_pipeline(
    repo_identifier: str,
    token: Optional[str] = None,
    output_path: Optional[str] = None,
    output_format: str = "txt",
    max_files: int = 500,
    max_file_size: int = 100_000,
    parse_data: bool = False,
) -> str:
    """Full pipeline: connect -> clone -> analyze -> build graph -> format."""

    # 1. Connect & clone
    connector = RepoConnector(repo_identifier, token=token)
    metadata = connector.get_metadata()
    print(f"[*] Repository: {metadata['name']} ({metadata['language']})")
    print(f"    Stars: {metadata['stars']}  Forks: {metadata['forks']}  License: {metadata.get('license','?')}")

    safe_name = metadata["name"].replace("/", "_")
    local_path = connector.clone()
    is_local_repo = connector.is_local

    try:
        # 2. Build tree
        print("[*] Building directory tree ...")
        tree_builder = TreeBuilder(local_path)
        tree_str = tree_builder.build()

        # 3. Analyze files
        print("[*] Analyzing source files ...")
        analyzer = CodeAnalyzer()
        data_parser = DataFileParser()
        graph_builder = KnowledgeGraphBuilder()
        graph_builder.add_repo_metadata(metadata)

        file_count = 0
        root = Path(local_path)

        for filepath in sorted(root.rglob("*")):
            if file_count >= max_files:
                print(f"[!] Reached max file limit ({max_files}).")
                break
            if filepath.is_dir():
                continue

            rel = filepath.relative_to(root)
            if any(part in SKIP_DIRS for part in rel.parts):
                continue
            if filepath.name in SKIP_FILES:
                continue

            ext = filepath.suffix.lower()
            rel_path = str(rel)

            # Documentation files
            if filepath.name in DOC_FILES:
                try:
                    doc_content = filepath.read_text(errors="ignore")
                    graph_builder.add_doc_content(rel_path, doc_content)
                except Exception:
                    pass

            # Data files
            if ext in DATA_EXTENSIONS and parse_data:
                try:
                    data_bytes = filepath.read_bytes()
                    if len(data_bytes) <= max_file_size * 5:
                        ds = data_parser.parse(rel_path, data_bytes, ext)
                        graph_builder.add_data_summary(ds)
                        file_count += 1
                except Exception:
                    pass
                continue

            if ext not in TEXT_EXTENSIONS:
                continue

            try:
                size = filepath.stat().st_size
                if size > max_file_size:
                    continue
                content = filepath.read_text(errors="ignore")
            except (OSError, UnicodeDecodeError):
                continue

            if ext in PARSEABLE_EXTENSIONS:
                analysis = analyzer.analyze_file(rel_path, content)
            else:
                analysis = {
                    "path": rel_path, "extension": ext,
                    "classes": [], "functions": [], "imports": [],
                    "exports": [], "global_variables": [], "decorators": [],
                    "lines": content.count("\n") + 1,
                    "docstrings": [], "todos": [], "complexity": {},
                }
                analyzer._extract_todos(content, analysis)

            graph_builder.add_file_analysis(analysis)
            file_count += 1

        print(f"[+] Analyzed {file_count} files ({len(graph_builder.data_summaries)} data files).")

        # 4. Dependencies & centrality
        print("[*] Resolving dependencies & computing centrality ...")
        dep_map = graph_builder.build_dependency_map()
        centrality = graph_builder.compute_centrality()

        # 5. Format output
        print("[*] Formatting output ...")
        outputs: dict[str, str] = {}

        if output_format in ("txt", "all"):
            outputs["txt"] = LLMFormatter.format_txt(metadata, tree_str, graph_builder, dep_map, centrality)
        if output_format in ("jsonl", "all"):
            outputs["jsonl"] = LLMFormatter.format_jsonl(graph_builder, metadata, dep_map, centrality)
        if output_format in ("md", "markdown", "all"):
            outputs["md"] = LLMFormatter.format_markdown(metadata, tree_str, graph_builder, dep_map, centrality)
        if output_format == "json":
            kg_json = {
                "metadata": metadata,
                "statistics": graph_builder.get_statistics(),
                "tree": tree_str,
                "files": [
                    {
                        "path": a["path"], "extension": a["extension"], "lines": a["lines"],
                        "classes": a["classes"], "functions": a["functions"],
                        "imports": a["imports"], "docstrings": a.get("docstrings", []),
                        "todos": a.get("todos", []), "complexity": a.get("complexity", {}),
                    }
                    for a in graph_builder.file_analyses
                ],
                "data_files": graph_builder.data_summaries,
                "dependencies": dep_map,
                "centrality": centrality,
                "inheritance": [
                    {"child": str(u), "parent": str(v)}
                    for u, v in graph_builder.iter_edges_with_relation("inherits")
                ],
                "graph": {
                    "nodes": [{"id": str(n), **{k: str(v) for k, v in d.items()}}
                              for n, d in graph_builder.iter_nodes()],
                    "edges": [{"source": str(u), "target": str(v), "relation": d.get("relation", "")}
                              for u, v, d in graph_builder.iter_edges()],
                },
            }
            outputs["json"] = json.dumps(kg_json, indent=2, default=str)

        # 6. Write output files
        base_name = output_path or safe_name
        if base_name.endswith((".txt", ".json", ".jsonl", ".md")):
            base_name = base_name.rsplit(".", 1)[0]

        for fmt, content in outputs.items():
            out_file = f"{base_name}_knowledge_graph.{fmt}"
            with open(out_file, "w") as f:
                f.write(content)
            lines_count = content.count("\n") + 1
            print(f"[+] Written: {out_file}  ({len(content):,} chars, {lines_count:,} lines)")

        primary_output = outputs.get(output_format, next(iter(outputs.values()), ""))
        return primary_output

    finally:
        if not is_local_repo and local_path and os.path.exists(local_path):
            shutil.rmtree(local_path, ignore_errors=True)
            print("[+] Cleaned up temporary clone.")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description="Generate a knowledge graph & tree from any GitHub repo for LLM input (igraph version).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
        Examples:
          python git_igraph.py pallets/flask
          python git_igraph.py https://github.com/fastapi/fastapi --token ghp_xxx
          python git_igraph.py owner/repo --format all
          python git_igraph.py owner/data-repo --parse-data --format md
          python git_igraph.py owner/repo --format json
        """),
    )
    parser.add_argument("repo", help="GitHub repo as 'owner/repo' or full URL")
    parser.add_argument("--token", default=None, help="GitHub PAT (or set GITHUB_TOKEN env var)")
    parser.add_argument("--output", "-o", default=None, help="Output file base name")
    parser.add_argument("--format", "-f", default="txt",
                        choices=["txt", "json", "jsonl", "md", "markdown", "all"],
                        help="Output format (default: txt)")
    parser.add_argument("--max-files", type=int, default=500, help="Max files to analyze (default: 500)")
    parser.add_argument("--max-file-size", type=int, default=100_000, help="Max file size in bytes (default: 100KB)")
    parser.add_argument("--parse-data", action="store_true", help="Parse data files (CSV, Excel, Parquet)")

    args = parser.parse_args()

    run_pipeline(
        repo_identifier=args.repo,
        token=args.token,
        output_path=args.output,
        output_format=args.format,
        max_files=args.max_files,
        max_file_size=args.max_file_size,
        parse_data=args.parse_data,
    )


if __name__ == "__main__":
    main()
